{
  "name": "@ronas-it/axios-api-client",
  "version": "0.3.0",
  "description": "Wrapper utilities for interaction with REST APIs using Axios",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup-node",
    "release": "npm publish",
    "lint": "npx tsc && npx eslint ./",
    "format": "npx prettier --write . && npm run lint -- --fix",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RonasIT/axios-api-client.git"
  },
  "keywords": [
    "query",
    "api",
    "typescript",
    "crud"
  ],
  "author": "Ronas IT",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/RonasIT/axios-api-client/issues"
  },
  "homepage": "https://github.com/RonasIT/axios-api-client#readme",
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/base-64": "^1.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "axios": "^1.17.0"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix",
    "*.{js,ts,css,md}": "prettier --write"
  },
  "dependencies": {
    "base-64": "^1.0.0",
    "jwt-decode": "^4.0.0",
    "typescript-eslint": "^8.60.1"
  }
}